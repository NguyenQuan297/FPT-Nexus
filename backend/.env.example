# JWT & first admin (set SEED_ADMIN_PASSWORD to create admin on startup)
# JWT_SECRET=your-long-random-secret
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=changeme
# SEED_ADMIN_UPDATE_EXISTING=false

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/leads
SYNC_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/leads
REDIS_URL=redis://localhost:6379/0
# LEAD_INGEST_QUEUE_KEY=queue:lead_ingest
SLA_HOURS=16
JOB_INTERVAL_MINUTES=5
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=./uploads

# Optional Telegram
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# Optional SMTP
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# ALERT_EMAIL_FROM=
# ALERT_EMAIL_TO=

# Optional S3 (otherwise files stored in UPLOAD_DIR)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=ap-southeast-1
# S3_BUCKET=
