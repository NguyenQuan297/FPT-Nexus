# JWT & first admin (set SEED_ADMIN_PASSWORD to create admin on startup)
# JWT_SECRET=your-long-random-secret
# SEED_ADMIN_USERNAME=admin
# SEED_ADMIN_PASSWORD=changeme
# SEED_ADMIN_UPDATE_EXISTING=false

DATABASE_URL=postgresql+asyncpg://<DB_USER>:<DB_PASS>@<DB_HOST>:5432/<DB_NAME>
SYNC_DATABASE_URL=postgresql://<DB_USER>:<DB_PASS>@<DB_HOST>:5432/<DB_NAME>
REDIS_URL=redis://localhost:6379/0
# LEAD_INGEST_QUEUE_KEY=queue:lead_ingest
SLA_HOURS=16
JOB_INTERVAL_MINUTES=5
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
UPLOAD_DIR=./uploads
# API + SPA single process (Dockerfile): path to Vite dist with index.html
# FRONTEND_DIST=./static

# Telegram: TELEGRAM_BOT_TOKEN required; optional TELEGRAM_BOT_USERNAME. Widget needs HTTPS + BotFather /setdomain; else set chat_id in Settings.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_BOT_USERNAME=
# TELEGRAM_CHAT_ID=

